PORT=8080
CORS_ORIGINS=http://localhost:8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chat
POSTGRES_HOST=chat-postgres
POSTGRES_URL=jdbc:postgresql://chat-postgres:5432/chat

MONGO_USERNAME=root
MONGO_PASSWORD=admin
MONGO_DB=chat
MONGO_HOST=chat-mongodb
MONGO_URI=mongodb://root:admin@chat-mongodb:27017/chat?authSource=admin

JPA_SHOW_SQL=false

JWT_SECRET=secret gerada pelo comando

JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000